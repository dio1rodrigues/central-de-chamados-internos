<section class="page-header">
  <div>
    <h1>
      <%= currentUser.role === "ADMIN"
        ? "Todos os chamados"
        : "Meus chamados"
      %>
    </h1>

    <p>Consulte e acompanhe as demandas registradas.</p>
  </div>

  <a href="/chamados/novo">
    Novo chamado
  </a>
</section>

<% if (currentUser.role === "ADMIN") { %>
  <form
    class="ticket-filters"
    action="/chamados"
    method="GET"
  >
    <div class="form-group">
      <label for="filter-status">Status</label>

      <select id="filter-status" name="status">
        <option value="">Todos</option>

        <% statusOptions.forEach((option) => { %>
          <option
            value="<%= option.value %>"
            <%= selectedFilters.status === option.value
              ? "selected"
              : ""
            %>
          >
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="filter-type">Tipo</label>

      <select id="filter-type" name="type">
        <option value="">Todos</option>

        <% typeOptions.forEach((option) => { %>
          <option
            value="<%= option.value %>"
            <%= selectedFilters.type === option.value
              ? "selected"
              : ""
            %>
          >
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-group">
      <label for="filter-priority">Prioridade</label>

      <select id="filter-priority" name="priority">
        <option value="">Todas</option>

        <% priorityOptions.forEach((option) => { %>
          <option
            value="<%= option.value %>"
            <%= selectedFilters.priority === option.value
              ? "selected"
              : ""
            %>
          >
            <%= option.label %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="filter-actions">
      <button type="submit">
        Filtrar
      </button>

      <a href="/chamados">
        Limpar filtros
      </a>
    </div>
  </form>
<% } %>

<% if (tickets.length === 0) { %>
  <div class="empty-state">
    Nenhum chamado foi encontrado.
  </div>
<% } else { %>
  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Protocolo</th>
          <th>Título</th>

          <% if (currentUser.role === "ADMIN") { %>
            <th>Solicitante</th>
          <% } %>

          <th>Tipo</th>
          <th>Prioridade</th>
          <th>Status</th>
          <th>Criação</th>
          <th>Ações</th>
        </tr>
      </thead>

      <tbody>
        <% tickets.forEach((ticket) => { %>
          <tr>
            <td><%= ticket.protocol %></td>
            <td><%= ticket.title %></td>

            <% if (currentUser.role === "ADMIN") { %>
              <td>
                <%= ticket.requester?.name || "Não informado" %>
              </td>
            <% } %>

            <td>
              <%= typeLabels[ticket.type] || ticket.type %>
            </td>

            <td>
              <%= priorityLabels[ticket.priority] || ticket.priority %>
            </td>

            <td>
              <%= statusLabels[ticket.status] || ticket.status %>
            </td>

            <td>
              <%= new Date(ticket.createdAt).toLocaleString("pt-BR") %>
            </td>

            <td>
              <a href="/chamados/<%= ticket._id %>">
                Ver detalhes
              </a>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
<% } %>