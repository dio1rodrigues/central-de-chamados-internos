<section class="page-header">
  <div>
    <span>Detalhes do chamado — <%= ticket.protocol %></span>
    <h1><%= ticket.title %></h1>
  </div>

  <a href="/chamados">
    Voltar
  </a>
</section>

<div class="ticket-details">
  <div>
    <strong>Status</strong>
    <span><%= statusLabels[ticket.status] %></span>
  </div>

  <div>
    <strong>Tipo</strong>
    <span><%= typeLabels[ticket.type] %></span>
  </div>

  <div>
    <strong>Prioridade</strong>
    <span><%= priorityLabels[ticket.priority] %></span>
  </div>

  <div>
    <strong>Solicitante</strong>
    <span><%= ticket.requester?.name || "Não informado" %></span>
  </div>

  <div>
    <strong>Criado em</strong>
    <span>
      <%= ticket.createdAt.toLocaleString("pt-BR") %>
    </span>
  </div>

  <div>
    <strong>Última atualização</strong>
    <span>
      <%= ticket.updatedAt.toLocaleString("pt-BR") %>
    </span>
  </div>
</div>

<% if (statusUpdated) { %>
  <div class="feedback feedback-success">
    Status atualizado com sucesso.
  </div>
<% } %>

<% if (statusError) { %>
  <div class="feedback feedback-error">
    <%= statusError %>
  </div>
<% } %>

<% if (currentUser.role === "ADMIN") { %>
  <section class="status-update">
    <h2>Atualizar andamento</h2>

    <p>
      Status atual:
      <strong><%= statusLabels[ticket.status] %></strong>
    </p>

    <form
      action="/chamados/<%= ticket._id %>/status"
      method="POST"
    >
      <div class="form-group">
        <label for="status">Novo status</label>

        <select
          id="status"
          name="status"
          required
        >
          <option value="">
            Selecione
          </option>

          <% statusOptions.forEach((option) => { %>
            <option value="<%= option.value %>">
              <%= option.label %>
            </option>
          <% }) %>
        </select>
      </div>

      <button type="submit">
        Atualizar status
      </button>
    </form>
  </section>
<% } %>

<section class="ticket-description">
  <h2>Descrição</h2>

  <p><%= ticket.description %></p>
</section>

<section class="status-history">
  <h2>Histórico de andamento</h2>

  <% if (
    !ticket.statusHistory ||
    ticket.statusHistory.length === 0
  ) { %>
    <p>Nenhuma alteração de status registrada.</p>
  <% } else { %>
    <ul>
      <% [...ticket.statusHistory]
        .reverse()
        .forEach((historyItem) => {
      %>
        <li>
          <div>
            <% if (historyItem.previousStatus) { %>
              <strong>
                <%= statusLabels[historyItem.previousStatus] %>
                →
                <%= statusLabels[historyItem.newStatus] %>
              </strong>
            <% } else { %>
              <strong>
                Chamado criado como
                <%= statusLabels[historyItem.newStatus] %>
              </strong>
            <% } %>
          </div>

          <div>
            Por
            <%= historyItem.changedBy?.name || "Usuário não informado" %>
            em
            <%= new Date(
              historyItem.changedAt
            ).toLocaleString("pt-BR") %>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</section>