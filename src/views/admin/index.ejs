<section>
  <h1>Área administrativa</h1>

  <p>
    Esta página pode ser acessada somente por administradores.
  </p>

  <div class="status-card">
    <strong>Usuário atual</strong>

    <span>
      <%= currentUser.name %>
    </span>

    <span>
      Perfil: <%= currentUser.role %>
    </span>
  </div>

  <div class="admin-actions">
    <p>
      <a href="/admin/users">
        Gerenciar usuários
      </a>
    </p>

    <p>
      <a href="/admin/auditoria">
        Consultar registros de auditoria
      </a>
    </p>
  </div>
</section>