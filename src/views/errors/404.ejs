<section class="error-page">
  <span class="error-code">404</span>

  <h1>
    <%= heading || "Página não encontrada" %>
  </h1>

  <p>
    <%= message ||
      "O endereço informado não existe ou não está mais disponível."
    %>
  </p>

  <a href="<%= backUrl || '/dashboard' %>">
    <%= backText || "Voltar ao dashboard" %>
  </a>
</section>